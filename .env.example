MYSQL_DATABASE=itbook_db
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# Used by user-service JWT generation/validation
APP_JWT_SECRET=replace-with-a-long-random-secret

# Optional for local IDE runs
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka/
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/itbook_db
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=app_password